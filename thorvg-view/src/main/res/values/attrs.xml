<resources>
    <attr name="rawRes" format="reference" />
    <attr name="assetName" format="string" />
    <attr name="speed" format="float" />
    <attr name="frameFrom" format="integer" />
    <attr name="frameTo" format="integer" />

    <declare-styleable name="LottieView">
        <attr name="rawRes" />
        <attr name="speed" />
        <attr name="android:repeatCount" />
        <attr name="android:repeatMode" />
        <attr name="android:autoStart" />
        <attr name="frameFrom" />
        <attr name="frameTo" />
    </declare-styleable>

    <declare-styleable name="SvgView">
        <attr name="rawRes" />
        <attr name="assetName" />
    </declare-styleable>
</resources>